# App backend
PORT=3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Select the app data source.
# local = current AsyncStorage prototype
# odoo = use the Odoo-backed tRPC hooks/routes
EXPO_PUBLIC_DATA_BACKEND=db

# Odoo service connection
# Run Odoo with: docker compose up --build
# First-run: open http://localhost:8069 → create database named "aquasachets"
ODOO_URL=http://localhost:8069
ODOO_DB=aquasachets
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# Product used by the mobile app for pack sales/production.
# Prefer a concrete Odoo product id once the database is seeded.
ODOO_PACK_PRODUCT_ID=
ODOO_PACK_PRODUCT_CODE=AQUASACHET_PACK

# Local proof-of-concept only. Leave false/empty in production.
# When false, business Odoo routes require the app user to be authenticated.
ODOO_PUBLIC_API=false
